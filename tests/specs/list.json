[
  {
    "name": "/list shows empty watchlist",
    "steps": [
      {
        "send": { "text": "/list" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "Your watchlist is empty. Tap ➕ Add to add your first coin." }
          }
        ]
      }
    ]
  },
  {
    "name": "list:show callback shows empty watchlist",
    "steps": [
      {
        "send": { "callback": "list:show" },
        "expect": [{ "method": "editMessageText" }]
      }
    ]
  },
  {
    "name": "add then list shows the coin",
    "steps": [
      {
        "send": { "callback": "addc:BTC" },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "list:show" },
        "expect": [{ "method": "editMessageText", "payload": { "text": "Your watchlist (1 coin):\n\n1. BTC — Bitcoin" } }]
      }
    ]
  },
  {
    "name": "remove coin from watchlist",
    "steps": [
      {
        "send": { "callback": "addc:BTC" },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "list:show" },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "list:rm:BTC" },
        "expect": [{ "method": "editMessageText" }]
      }
    ]
  }
]
