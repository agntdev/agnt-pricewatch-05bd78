[
  {
    "name": "Common Coins button shows popular coins list",
    "steps": [
      {
        "send": { "callback": "add_common" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "Quick-add popular coins to your watchlist:" }
          }
        ]
      }
    ]
  },
  {
    "name": "picking BTC from common coins adds it",
    "steps": [
      {
        "send": { "callback": "add_common" },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "addc:BTC" },
        "expect": [{ "method": "editMessageText" }]
      }
    ]
  }
]
